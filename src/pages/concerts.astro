---
import Navigation from "../components/Navigation.astro";
import Layout from "../layouts/Layout.astro";
import Concert from "../components/Concert.astro";

let concerts = [
  {
    date: "Sunday, May 17 2025",
    venue: "Marlboro Jewish Center",
    place: "Marlboro, NJ",
  },
  {
    date: "Sunday, May 31 2025",
    venue: "Temple Sinai",
    place: "Dresher, PA",
  },
];
---

<Layout>
  <Navigation pageTitle="concerts" />
  <div class="container mx-auto flex mt-4 gap-y-4 justify-center items-center">
    <div
      class="flex flex-col gap-y-4 items-start justify-center w-full max-w-xl"
    >
      {
        concerts.map((concert) => (
          <Concert
            date={concert.date}
            place={concert.place}
            venue={concert.venue}
          />
        ))
      }
    </div>
  </div>
</Layout>
