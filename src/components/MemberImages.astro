---
import MemberImage from "./MemberImage.svelte";

interface Props {
  memberImages: ImageMetadata[];
  names: string[];
  bios: string[];
}

const { memberImages, names, bios } = Astro.props;
---

<div
  class="grid max-sm:grid-cols-1 max-md:grid-cols-2 grid-cols-3 gap-x-2 gap-y-2 content-center"
>
  {
    memberImages.map((memberImage, index) => (
      <MemberImage
        imageSource={memberImage.src}
        name={names[index]}
        bio={bios[index]}
        client:load
      />
    ))
  }
</div>
