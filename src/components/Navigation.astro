---
import Logo from "../assets/logos/logo_5.png";
import { Image } from "astro:assets";

interface Props {
  pageTitle: string;
}
const { pageTitle } = Astro.props;
---

<nav class="container mx-auto mt-6 text-[#2C2C2C]">
  <div class="flex flex-row justify-between items-center">
    <div class="flex items-center justify-center">
      <Image src={Logo} alt="Group logo" class="w-auto h-20" />
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-button"
      class="md:hidden text-2xl p-2"
      aria-label="Toggle menu"
    >
      <span id="menu-icon">☰</span>
    </button>

    <!-- Desktop menu -->
    <ul class="hidden md:flex flex-row gap-4 list-none">
      <li
        class:list={[
          { "font-bold": pageTitle === "about" },
          { "text-[#1C63AD]": pageTitle === "about" },
          "list-none",
          "text-xl",
        ]}
      >
        <a href="/njcce-website">About Us</a>
      </li>
      <li
        class:list={[
          { "font-bold": pageTitle === "members" },
          { "text-[#1C63AD]": pageTitle === "members" },
          "list-none",
          "text-xl",
        ]}
      >
        <a href="/njcce-website/members/">Members</a>
      </li>
      <li
        class:list={[
          { "font-bold": pageTitle === "concerts" },
          { "text-[#1C63AD]": pageTitle === "concerts" },
          "list-none",
          "text-xl",
        ]}
      >
        <a href="/njcce-website/concerts/">Concert Schedule</a>
      </li>
      <li
        class:list={[
          { "font-bold": pageTitle === "recordings" },
          { "text-[#1C63AD]": pageTitle === "recordings" },
          "list-none",
          "text-xl",
        ]}
      >
        <a href="/njcce-website/recordings/">Recordings</a>
      </li>
      <li
        class:list={[
          { "font-bold": pageTitle === "contact" },
          { "text-[#1C63AD]": pageTitle === "contact" },
          "list-none",
          "text-xl",
        ]}
      >
        <a href="/njcce-website/contact/">Contact Us</a>
      </li>
    </ul>
  </div>

  <!-- Mobile menu -->
  <ul id="mobile-menu" class="hidden md:hidden flex-col gap-4 mt-4 list-none">
    <li
      class:list={[
        { "font-bold": pageTitle === "about" },
        { "text-[#1C63AD]": pageTitle === "about" },
        "list-none",
        "text-xl",
      ]}
    >
      <a href="/njcce-website">About Us</a>
    </li>
    <li
      class:list={[
        { "font-bold": pageTitle === "members" },
        { "text-[#1C63AD]": pageTitle === "members" },
        "list-none",
        "text-xl",
      ]}
    >
      <a href="/njcce-website/members/">Members</a>
    </li>
    <li
      class:list={[
        { "font-bold": pageTitle === "concerts" },
        { "text-[#1C63AD]": pageTitle === "concerts" },
        "list-none",
        "text-xl",
      ]}
    >
      <a href="/njcce-website/concerts/">Concert Schedule</a>
    </li>
    <li
      class:list={[
        { "font-bold": pageTitle === "recordings" },
        { "text-[#1C63AD]": pageTitle === "recordings" },
        "list-none",
        "text-xl",
      ]}
    >
      <a href="/njcce-website/recordings/">Recordings</a>
    </li>
    <li
      class:list={[
        { "font-bold": pageTitle === "contact" },
        { "text-[#1C63AD]": pageTitle === "contact" },
        "list-none",
        "text-xl",
      ]}
    >
      <a href="/njcce-website/contact/">Contact Us</a>
    </li>
  </ul>
</nav>

<script>
  const button = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");
  const icon = document.getElementById("menu-icon");

  button?.addEventListener("click", () => {
    const isHidden = menu?.classList.contains("hidden");

    if (isHidden) {
      menu?.classList.remove("hidden");
      menu?.classList.add("flex");
      if (icon) icon.textContent = "✕";
    } else {
      menu?.classList.add("hidden");
      menu?.classList.remove("flex");
      if (icon) icon.textContent = "☰";
    }
  });
</script>
