---
let { date, venue, place } = Astro.props;
---

<div class="flex flex-col">
  <div class="flex justify-center gap-4">
    {
      date && (
        <div class="border-1 border-black rounded-xl">
          <div class="w-28 h-28 p-2 text-xl text-center flex justify-center items-center">
            {date}
          </div>
        </div>
      )
    }
    <div
      class="flex-1 text-base text-wrap flex flex-col items-start justify-center"
    >
      {
        venue && place && (
          <p>
            {venue} in {place}
          </p>
        )
      }
      <hr class="border-1 rounded-xl border-blue-200 w-3/5" />
    </div>
  </div>
</div>
